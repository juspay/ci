cabal-version:   3.0
name:            ci
version:         0.1.0.0
license:         NONE
build-type:      Simple

common warnings
    ghc-options: -Wall

executable ci
    import:           warnings
    main-is:          Main.hs
    build-depends:
        , aeson
        , base
        , bytestring
        , containers
        , process
        , text
        , which
    hs-source-dirs:   src
    default-language: Haskell2010
